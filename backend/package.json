{
  "name": "hs-blog-backend",
  "version": "1.0.0",
  "description": "技术博客后端服务",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:dev": "prisma db push && node prisma/seed.js",
    "db:prod:generate": "prisma generate --schema prisma/schema.mysql.prisma",
    "db:prod:migrate": "prisma migrate deploy --schema prisma/schema.mysql.prisma && node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "blog",
    "express",
    "mysql"
  ],
