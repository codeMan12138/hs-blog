PORT=3000
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
UPLOAD_DIR=./uploads

# ============================================
# 数据库配置 - 根据环境选择 SQLite 或 MySQL
# ============================================

# 开发环境 (SQLite - 无需安装数据库，数据存储在本地文件)
DATABASE_URL="file:./dev.db"

# 生产环境 (MySQL - 需要安装 MySQL 服务，并使用 schema.mysql.prisma)
# DATABASE_URL="mysql://root:your_password@localhost:3306/hs_blog"
